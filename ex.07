let numeros = []
for(let i=0; i<5; i++ ){
    numeros.push(Number(prompt(`digite um numero ${i + 1} numero:` )))
}
let maior = numeros[0]
for(let i =1; i< numeros.length; i++){
    if(numeros[i] > maior){
        maior = numeros[i];
    }
}
let posicao = numeros.indexOf(maior);
alert(`o maior numero e ${maior}`)
alert(`Ele esta na posiçao ${posicao + 1}`)
